#Mary-Ann's test
import unittest
import numpy as np
from PIL import Image
import Quartz
from mac_capture import capture_screen, capture_window_image


class TestCapture(unittest.TestCase):

    def test_capture_screen_returns_array(self):
        """Test that capture_screen returns a valid NumPy RGB array."""

        screen = capture_screen()

        self.assertIsInstance(screen, np.ndarray)
        self.assertEqual(screen.ndim, 3)
        self.assertEqual(screen.shape[2], 3)
        self.assertEqual(screen.dtype, np.uint8)
        self.assertTrue(screen.size > 0, "Screen capture should contain pixel data")

    def test_capture_window_image_returns_image(self):
        """Test that capture_window_image returns a valid PIL RGBA Image."""

        # Get the list of on-screen windows and capture the frontmost one
        window_list = Quartz.CGWindowListCopyWindowInfo(
            Quartz.kCGWindowListOptionOnScreenOnly,
            Quartz.kCGNullWindowID
        )

        if not window_list:
            self.skipTest("No visible windows found for capture.")

        front_window_id = window_list[0]['kCGWindowNumber']
        img = capture_window_image(front_window_id)

        # Skip test if capture fails (usually happens if the IDE doesn't have screen recording permissions)
        if img is None:
            self.skipTest(
                "Window capture failed. Make sure your IDE has Screen Recording permission. "
                "You can check this by going to System Settings > Security & Privacy."
            )

        self.assertIsInstance(img, Image.Image)
        self.assertEqual(img.mode, "RGBA")
        self.assertTrue(img.width > 0 and img.height > 0,
                        "Captured image should have valid dimensions")


if __name__ == "__main__":
    unittest.main()
